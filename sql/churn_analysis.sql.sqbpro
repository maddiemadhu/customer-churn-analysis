><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">SELECT count(*) FROM clean_telco_churn;
--Churn Rate 
SELECT ROUND(AVG(Churn) * 100, 2) AS churn_rate_percentage FROM clean_telco_churn;

--Churn by Contract 
SELECT Contract, COUNT(*) AS total_customers, ROUND(AVG(Churn) * 100, 2) AS churn_rate FROM clean_telco_churn GROUP BY Contract;

--Churn by TenureGroup
SELECT TenureGroup, COUNT(*) AS total_customers, ROUND(AVG(Churn) * 100, 2) AS churn_rate FROM clean_telco_churn GROUP BY TenureGroup;

--Revenue at Risk
SELECT ROUND(SUM(MonthlyCharges), 2) AS total_revenue, ROUND(SUM(CASE WHEN Churn = 1 THEN MonthlyCharges ELSE 0 END), 2) AS churned_revenue FROM clean_telco_churn;

--Churn by PaymentMethod
SELECT PaymentMethod, COUNT(*) AS total_customers, ROUND(AVG(Churn) * 100, 2) AS churn_rate FROM clean_telco_churn GROUP BY PaymentMethod ORDER BY churn_rate DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
